# === Blu Backend Environment Variables ===
# Copy this file to .env (locally) or set these in Railway Variables (production)

# --------- JIRA INTEGRATION ---------
# Generate API token: https://id.atlassian.com/manage/api-tokens
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_EMAIL=your-email@yourcompany.com
JIRA_API_TOKEN=your_atlassian_api_token

# Optional: customize the Jira query
JIRA_JQL=assignee = currentUser() AND status not in (Done, Closed) ORDER BY priority DESC
JIRA_MAX_RESULTS=10

# --------- GOOGLE CALENDAR ---------
# 1. Go to https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Create service account > create key > download JSON
# 3. Paste entire JSON below (minified, one line)
# 4. Share your calendar with the service account email with 'See all event details'
GOOGLE_USER_EMAIL=your-email@yourcompany.com
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}'

# Optional: narrow the calendar query
GOOGLE_DAYS_AHEAD=3
GOOGLE_QUIET_HOURS_START=6
